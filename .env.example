# ============================================================================
# VulnSeeker Environment Example
# VulnSeeker 环境变量范例
#
# Copy this file to ".env" in the project root and fill in real values.
# 首次部署时，请复制本文件为项目根目录下的 ".env"，然后填写真实配置。
# ============================================================================


# ============================================================================
# MySQL Database / MySQL 数据库
# ============================================================================

# MySQL server host.
# MySQL 服务地址。
MYSQL_HOST=localhost

# MySQL server port.
# MySQL 服务端口。
MYSQL_PORT=3306

# MySQL username.
# MySQL 用户名。
MYSQL_USER=root

# MySQL password.
# MySQL 密码。
MYSQL_PASSWORD=your_mysql_password

# Database name used by VulnSeeker.
# VulnSeeker 使用的数据库名。
MYSQL_DATABASE=vulnseeker

# ============================================================================
# JWT Authentication / JWT 认证
# ============================================================================

# Secret key for signing access tokens. Replace this in production.
# 用于签发登录 token 的密钥；生产环境必须替换为强随机字符串。
JWT_SECRET_KEY=CHANGE_ME_USE_strong_random_key_here

# ============================================================================
# Backend / 后端服务
# ============================================================================

# Backend bind host and port.
# 后端监听地址和端口。
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend origin used by development CORS and documentation.
# 前端地址，用于开发环境 CORS 和文档说明。
FRONTEND_URL=http://localhost:5173

# Optional Python interpreter for the analysis worker.
# 可选：指定分析 worker 使用的 Python 解释器；不填则使用启动后端的解释器。
# ANALYSIS_PYTHON=D:\Projects\PythonProject\VulnSeeker\.venv\Scripts\python.exe


# ============================================================================
# CodeQL
# ============================================================================

# Path to CodeQL CLI executable. Required.
# CodeQL CLI 可执行文件路径，必填。
#
# Windows example:
# Windows 示例：
# CODEQL_PATH=D:\Tools\codeql\codeql.cmd
#
# Linux / macOS example:
# Linux / macOS 示例：
# CODEQL_PATH=/opt/codeql/codeql
CODEQL_PATH=/path/to/codeql


# ============================================================================
# GitHub
# ============================================================================

# Optional GitHub token for higher API rate limits.
# 可选：GitHub token，用于提高 API 访问速率限制。
# GITHUB_TOKEN=ghp_your_token_here

# Optional GitHub Enterprise API URL. Default is https://api.github.com.
# 可选：GitHub Enterprise API 地址；默认使用 https://api.github.com。
# GITHUB_API_URL=https://github.your-company.com/api/v3

# Optional SSL verification switch for self-signed/internal certificates.
# 可选：SSL 证书校验开关；内网自签证书场景可设为 false。
# GITHUB_SSL_VERIFY=false


# ============================================================================
# LLM Common Settings / LLM 通用配置
# ============================================================================

# Provider selection.
# 模型服务提供方。
# Supported values include:
# 支持值包括：
# openai, azure, gemini, bedrock, anthropic, mistral, groq, openrouter,
# huggingface, cohere, ollama, minimax
#PROVIDER=openai

# Model name. This depends on the selected provider.
# 模型名称；取值取决于 PROVIDER。
#MODEL=gpt-4o

# Optional generation parameters. Keep defaults for stable security analysis.
# 可选生成参数。安全审查建议保持默认值，避免输出过于发散。
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.2
LLM_TIMEOUT=300
LLM_MAX_RETRIES=3


# ============================================================================
# OpenAI Official / OpenAI 官方接口
# ============================================================================

# Official OpenAI API key.
# OpenAI 官方 API Key。
OPENAI_API_KEY=sk-your_api_key
MODEL=gpt-4o
PROVIDER=openai

# ============================================================================
# OpenAI-Compatible APIs / OpenAI 兼容接口
# ============================================================================

# Many vendors provide OpenAI-compatible chat/completions APIs, such as
# Alibaba Cloud Model Studio (Bailian), internal gateways, or proxy services.
# 许多厂商提供 OpenAI 兼容格式接口，例如阿里云百炼、内网网关或中转服务。
#
# Keep PROVIDER=openai, set MODEL to the vendor model name, and set a base URL.
# 保持 PROVIDER=openai，将 MODEL 设置为厂商模型名，并填写兼容接口 base URL。
#
# Alibaba Cloud Bailian example:
# 阿里云百炼示例：

# PROVIDER=openai
# MODEL=qwen-plus
# OPENAI_API_KEY=your_bailian_api_key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================================
# MiniMax
# ============================================================================

# PROVIDER=minimax
# MODEL=MiniMax-M2.7
# MINIMAX_API_KEY=your_api_key
#
# Optional endpoint. China endpoint is used by default in code when omitted.
# 可选接口地址；不填时代码会使用默认中国区 endpoint。
# MINIMAX_API_BASE=https://api.minimax.io/v1
#
# OpenAI-compatible MiniMax variables are accepted as fallbacks.
# 也兼容 MiniMax 的 OpenAI 格式变量作为兜底。
# OPENAI_API_KEY=your_api_key
# OPENAI_BASE_URL=https://api.minimaxi.com/v1


# ============================================================================
# Azure OpenAI
# ============================================================================

# PROVIDER=azure
# MODEL=gpt-4o
# AZURE_OPENAI_API_KEY=your_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview


# ============================================================================
# Google AI Studio / Gemini
# ============================================================================

# PROVIDER=gemini
# MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=your_api_key


# ============================================================================
# Anthropic
# ============================================================================

# PROVIDER=anthropic
# MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your_api_key


# ============================================================================
# OpenRouter
# ============================================================================

# PROVIDER=openrouter
# MODEL=minimax/minimax-m2.7
# OPENROUTER_API_KEY=your_api_key


# ============================================================================
# AWS Bedrock
# ============================================================================

# PROVIDER=bedrock
# MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_REGION_NAME=us-east-1
#
# Choose one authentication method.
# 任选一种认证方式。
#
# Method 1: AWS SSO / profile.
# 方式 1：AWS SSO / profile。
# AWS_PROFILE=your-profile
#
# Method 2: Static IAM credentials.
# 方式 2：静态 IAM 凭据。
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
#
# Method 3: Temporary STS credentials.
# 方式 3：临时 STS 凭据。
# AWS_ACCESS_KEY_ID=ASIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...


# ============================================================================
# Ollama
# ============================================================================

# PROVIDER=ollama
# MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434


# ============================================================================
# Logging / 日志
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# 日志级别：DEBUG、INFO、WARNING、ERROR、CRITICAL。
LOG_LEVEL=INFO

# Optional log file path. Leave empty to disable file logging.
# 可选日志文件路径；留空表示不写文件日志。
LOG_FILE=

# Log format: default or json.
# 日志格式：default 或 json。
LOG_FORMAT=default

# Console format verbosity.
# 控制控制台日志格式详细程度。
LOG_VERBOSE_CONSOLE=true

# Third-party library logging verbosity, such as LiteLLM, urllib3, requests.
# 第三方库日志级别，例如 LiteLLM、urllib3、requests。
THIRD_PARTY_LOG_LEVEL=ERROR
